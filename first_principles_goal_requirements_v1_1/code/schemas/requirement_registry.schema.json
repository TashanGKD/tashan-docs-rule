{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RequirementRegistry",
  "type": "object",
  "required": [
    "meta",
    "requirements"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "name",
        "total_requirements",
        "tier_definitions",
        "goals"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "total_requirements": {
          "type": "integer",
          "minimum": 1
        },
        "tier_definitions": {
          "type": "object"
        },
        "goals": {
          "type": "object"
        }
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "goal",
          "group",
          "tier",
          "kind",
          "statement",
          "parent",
          "codifiable",
          "representation_hint",
          "source_seq"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(M0|G[0-8])-\\d{3}$"
          },
          "goal": {
            "type": "string",
            "pattern": "^(M0|G[0-8])$"
          },
          "group": {
            "type": "string",
            "minLength": 1
          },
          "tier": {
            "type": "string",
            "enum": [
              "hard",
              "deferred",
              "engineering"
            ]
          },
          "kind": {
            "type": "string"
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "parent": {
            "type": "string",
            "pattern": "^(M0|G[0-8])\\.\\d+$"
          },
          "codifiable": {
            "type": "boolean"
          },
          "representation_hint": {
            "type": "string"
          },
          "source_seq": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}